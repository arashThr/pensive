{{template "header" .}}

<div class="px-4 sm:px-6 lg:px-8 py-16 sm:py-20 max-w-6xl mx-auto">

  <!-- Hero -->
  <section class="grid lg:grid-cols-2 gap-12 lg:gap-14 items-center">
    <div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white">
        Your searchable <span class="text-violet-200">memory</span> of the web
      </h1>
      <p class="mt-4 text-lg text-slate-300 max-w-prose">
        Smart bookmarking with full-content capture and fast search.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="/signup" class="inline-flex justify-center items-center gap-2 rounded-lg bg-violet-600 px-6 py-3 font-semibold text-white hover:bg-violet-500 transition-colors shadow-lg shadow-violet-600/25">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Start saving for free
        </a>
        <a href="/signin" class="inline-flex justify-center items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
          Sign in
        </a>
      </div>

      <div class="mt-8 space-y-3">
        <div class="flex items-center gap-3 text-sm text-slate-300">
          <div class="flex-shrink-0 w-5 h-5 rounded-full bg-violet-500/20 flex items-center justify-center">
            <svg class="w-3 h-3 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          Full content capture (not just titles)
        </div>
        <div class="flex items-center gap-3 text-sm text-slate-300">
          <div class="flex-shrink-0 w-5 h-5 rounded-full bg-violet-500/20 flex items-center justify-center">
            <svg class="w-3 h-3 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          Search across everything you saved
        </div>
        <div class="flex items-center gap-3 text-sm text-slate-300">
          <div class="flex-shrink-0 w-5 h-5 rounded-full bg-violet-500/20 flex items-center justify-center">
            <svg class="w-3 h-3 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          Save from browser + Telegram
        </div>
      </div>
    </div>

    <div class="relative">
      <!-- Subtle glow effect -->
      <div class="absolute -inset-1 bg-gradient-to-r from-violet-600/20 to-fuchsia-600/20 rounded-xl blur-xl"></div>
      <div class="relative rounded-xl overflow-hidden border border-white/10 bg-white/5">
        <div class="aspect-video">
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/N7tQpBjNMck"
            title="Pensive Demo"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen>
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Save from anywhere (Integrations) -->
  <section id="integrations" class="mt-16 sm:mt-20">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Save from anywhere</h2>
      <p class="mt-3 text-slate-400">One-click saving on desktop browsers, or forward links from your phone via Telegram.</p>
    </div>

    <div class="mt-10 grid sm:grid-cols-3 gap-6">
      <!-- Chrome -->
      <a href="https://chromewebstore.google.com/detail/pensive-save-search-what/klmginbbicjdpaodcbokdjbhnbaocomd" 
         target="_blank" rel="noopener"
         class="group relative flex flex-col items-center p-6 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-white/20 transition-all">
        <div class="w-16 h-16 rounded-2xl p-[2px] mb-4">
          <div class="w-full h-full rounded-2xl flex items-center justify-center">
            <img src="/assets/icons/chrome.svg"/>
          </div>
        </div>
        <h3 class="text-lg font-semibold text-white">Chrome</h3>
        <p class="mt-1 text-sm text-slate-400 text-center">Save with one click from Chrome</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-violet-300 group-hover:text-violet-200">
          Install extension
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>

      <!-- Firefox -->
      <a href="https://addons.mozilla.org/en-US/firefox/addon/pensive/" 
         target="_blank" rel="noopener"
         class="group relative flex flex-col items-center p-6 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-white/20 transition-all">
        <div class="w-16 h-16 rounded-2xl p-[2px] mb-4">
          <div class="w-full h-full rounded-2xl flex items-center justify-center">
            <img src="/assets/icons/firefox.svg"/>
          </div>
        </div>
        <h3 class="text-lg font-semibold text-white">Firefox</h3>
        <p class="mt-1 text-sm text-slate-400 text-center">Works seamlessly with Firefox</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-violet-300 group-hover:text-violet-200">
          Get add-on
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>

      <!-- Telegram -->
      <a href="https://t.me/GetPensiveBot" 
         target="_blank" rel="noopener"
         class="group relative flex flex-col items-center p-6 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-white/20 transition-all">
        <div class="w-16 h-16 rounded-2xl p-[4px] mb-4">
          <div class="w-full h-full rounded-2xl flex items-center justify-center">
            <img src="/assets/icons/telegram.svg"/>
          </div>
        </div>
        <h3 class="text-lg font-semibold text-white">Telegram</h3>
        <p class="mt-1 text-sm text-slate-400 text-center">Forward links from mobile</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-violet-300 group-hover:text-violet-200">
          Open @GetPensiveBot
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>
    </div>

    <div class="mt-6 text-center">
      <a href="/integrations" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors">
        Learn more about integrations
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Weekly Podcast -->
  <section class="mt-16 sm:mt-20">
    <div class="rounded-xl border border-violet-500/30 bg-violet-500/5 p-6 sm:p-8">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-violet-500/10 border border-violet-500/30 px-3 py-1 text-sm font-medium text-violet-200 mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
            New feature
          </div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white">Your bookmarks, as a podcast</h2>
          <p class="mt-3 text-slate-300">
            Get a weekly audio summary of your saved articles. AI reads through your bookmarks and creates a podcast you can listen to anywhere.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-violet-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              AI-generated summaries of your saved content
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-violet-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Delivered via email or Telegram
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-violet-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Choose your delivery day
            </li>
          </ul>
          <div class="mt-6">
            <a href="/signup" class="inline-flex items-center gap-2 rounded-lg bg-violet-600 px-5 py-3 font-semibold text-white hover:bg-violet-500 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Try it free
            </a>
          </div>
        </div>
        
        <!-- Audio Wave Visualization -->
        <div class="flex items-center justify-center">
          <div class="relative w-full max-w-xs aspect-square">
            <!-- Circular background -->
            <div class="absolute inset-0 rounded-full bg-violet-500/10 border border-violet-500/20"></div>
            
            <!-- Audio wave bars -->
            <div class="absolute inset-0 flex items-center justify-center gap-1">
              <style>
                @keyframes audioWave {
                  0%, 100% { height: 20%; }
                  50% { height: 80%; }
                }
                .audio-bar { animation: audioWave 1s ease-in-out infinite; }
                .audio-bar:nth-child(1) { animation-delay: 0s; }
                .audio-bar:nth-child(2) { animation-delay: 0.1s; }
                .audio-bar:nth-child(3) { animation-delay: 0.2s; }
                .audio-bar:nth-child(4) { animation-delay: 0.3s; }
                .audio-bar:nth-child(5) { animation-delay: 0.4s; }
                .audio-bar:nth-child(6) { animation-delay: 0.3s; }
                .audio-bar:nth-child(7) { animation-delay: 0.2s; }
              </style>
              <div class="audio-bar w-2 sm:w-3 bg-violet-400 rounded-full" style="height: 30%;"></div>
              <div class="audio-bar w-2 sm:w-3 bg-violet-400 rounded-full" style="height: 50%;"></div>
              <div class="audio-bar w-2 sm:w-3 bg-violet-400 rounded-full" style="height: 70%;"></div>
              <div class="audio-bar w-2 sm:w-3 bg-violet-500 rounded-full" style="height: 90%;"></div>
              <div class="audio-bar w-2 sm:w-3 bg-violet-400 rounded-full" style="height: 70%;"></div>
              <div class="audio-bar w-2 sm:w-3 bg-violet-400 rounded-full" style="height: 50%;"></div>
              <div class="audio-bar w-2 sm:w-3 bg-violet-400 rounded-full" style="height: 30%;"></div>
            </div>
            
            <!-- Headphone icon overlay -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-slate-950/80 border border-white/10 flex items-center justify-center">
                <svg class="w-10 h-10 sm:w-12 sm:h-12 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="mt-16 sm:mt-20">
    <div class="flex items-end justify-center gap-6">
      <div>
        <h2 class="text-xl font-semibold text-white">Save and search with the help of AI</h2>
      </div>
    </div>

    <div id="slider" class="relative mt-8 max-w-2xl mx-auto">
      <div class="overflow-hidden rounded-xl border border-white/10 bg-white/5">
        <div id="slider-track" class="flex transition-transform duration-300 ease-in-out">
          <div class="w-full shrink-0"><img src="/assets/promo/screenshots/library.jpg" alt="Library view" class="w-full h-auto"></div>
          <div class="w-full shrink-0"><img src="/assets/promo/screenshots/search.jpg" alt="Search" class="w-full h-auto"></div>
          <div class="w-full shrink-0"><img src="/assets/promo/screenshots/search-recent.jpg" alt="Recent search" class="w-full h-auto"></div>
          <div class="w-full shrink-0"><img src="/assets/promo/screenshots/link-page.jpg" alt="Link page" class="w-full h-auto"></div>
          <div class="w-full shrink-0"><img src="/assets/promo/screenshots/extension-saved.jpg" alt="Saved from extension" class="w-full h-auto"></div>
        </div>
      </div>

      <button id="prev-btn" type="button" class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-slate-950/70 border border-white/10 p-2 text-white hover:bg-slate-950 transition-colors" aria-label="Previous slide">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button id="next-btn" type="button" class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-slate-950/70 border border-white/10 p-2 text-white hover:bg-slate-950 transition-colors" aria-label="Next slide">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>

      <div class="mt-4 flex items-center justify-between gap-4">
        <div id="slide-caption" class="text-sm text-slate-300">
          <span data-slide="0">Library</span>
          <span data-slide="1" class="hidden">Search</span>
          <span data-slide="2" class="hidden">Recent</span>
          <span data-slide="3" class="hidden">Link</span>
          <span data-slide="4" class="hidden">Extension</span>
        </div>

        <div class="flex gap-2">
          <button class="slider-dot h-2.5 w-2.5 rounded-full bg-white/20 hover:bg-white/30" data-slide="0" aria-label="Go to slide 1"></button>
          <button class="slider-dot h-2.5 w-2.5 rounded-full bg-white/20 hover:bg-white/30" data-slide="1" aria-label="Go to slide 2"></button>
          <button class="slider-dot h-2.5 w-2.5 rounded-full bg-white/20 hover:bg-white/30" data-slide="2" aria-label="Go to slide 3"></button>
          <button class="slider-dot h-2.5 w-2.5 rounded-full bg-white/20 hover:bg-white/30" data-slide="3" aria-label="Go to slide 4"></button>
          <button class="slider-dot h-2.5 w-2.5 rounded-full bg-white/20 hover:bg-white/30" data-slide="4" aria-label="Go to slide 5"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- Everything you need -->
  <section class="mt-16 sm:mt-20">
    <div class="max-w-3xl">
      <h2 class="text-xl font-semibold text-white">Everything you need to build your knowledge base</h2>
      <p class="mt-2 text-sm text-slate-400">
        Capture what you read, keep it searchable, and own it long-term.
      </p>
    </div>

    <div class="mt-8 grid md:grid-cols-2 gap-6">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6 sm:p-8">
        <div class="flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-white">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white">Designed for search</h3>
        </div>
        <p class="mt-2 text-sm text-slate-300">Full content capture so you can search inside what you saved, not just titles.</p>
        <ul class="mt-4 space-y-1 text-sm text-slate-300">
          <li>• Full-text indexing</li>
          <li>• Tags, domains, and dates</li>
          <li>• Ask questions with AI (hosted)</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6 sm:p-8">
        <div class="flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-white">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white">Save from anywhere</h3>
        </div>
        <p class="mt-2 text-sm text-slate-300">Browser extensions and Telegram make saving fast on desktop and mobile.</p>
        <ul class="mt-4 space-y-1 text-sm text-slate-300">
          <li>• Chrome + Firefox extensions</li>
          <li>• Telegram bot forwarding</li>
          <li>• One-click capture</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6 sm:p-8">
        <div class="flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-white">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white">AI summaries and tags</h3>
        </div>
        <p class="mt-2 text-sm text-slate-300">Optional AI helps you skim, organize, and revisit later.</p>
        <ul class="mt-4 space-y-1 text-sm text-slate-300">
          <li>• Automatic summaries</li>
          <li>• Smart topic tags</li>
          <li>• Clean text extraction</li>
        </ul>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6 sm:p-8">
        <div class="flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-white">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 10-8 0v4" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white">Data ownership and privacy</h3>
        </div>
        <p class="mt-2 text-sm text-slate-300">Your bookmarks are yours. Export anytime, no lock-in.</p>
        <ul class="mt-4 space-y-1 text-sm text-slate-300">
          <li>• Secure cloud storage</li>
          <li>• Import and export anytime</li>
          <li>• Your content, your control</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Why I built this -->
  <section class="mt-16 sm:mt-20">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-xl font-semibold text-white">Why I built this</h2>
      <div class="mt-3 space-y-4 text-sm text-slate-300">
        <p>
          Years ago I found Gordon Bell’s <a class="text-violet-200 hover:text-white transition-colors" href="https://en.wikipedia.org/wiki/MyLifeBits" target="_blank" rel="noopener">MyLifeBits</a> research project.
          The idea stuck: can we preserve what we read and make it searchable?
        </p>
        <p>
          I read and share a lot of links (Hacker News, blogs, docs). The good stuff gets lost in browser bookmarks and buried by SEO.
          Pocket was the closest fit for me for a while, until it shut down.
        </p>
        <p>
          So I built Pensive to solve this problem. Your bookmarks shouldn't depend on a service that can change direction.
          Read the longer story <a class="text-violet-200 hover:text-white transition-colors" href="https://arashtaher.com/blog/introducing-pensive/" target="_blank" rel="noopener">here</a>, or <a class="text-violet-200 hover:text-white transition-colors" href="/contact">tell me</a> what you think.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="mt-16 sm:mt-20">
    <h2 class="text-xl font-semibold text-white text-center">Simple, transparent pricing</h2>
    <p class="mt-2 text-sm text-slate-400 text-center">Start free, upgrade when you need more.</p>

    <div class="mt-8 grid lg:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- Free -->
      <div class="rounded-xl border border-white/10 bg-white/5 p-6 sm:p-8">
        <div class="flex items-baseline justify-between gap-4">
          <div class="text-lg font-semibold text-white">Hosted</div>
          <div class="text-sm text-slate-400">Free</div>
        </div>
        <div class="mt-2 text-4xl font-bold text-white">$0</div>
        <div class="mt-2 text-sm text-slate-300">Try it out with generous daily limits.</div>

        <ul class="mt-5 space-y-2 text-sm text-slate-300">
