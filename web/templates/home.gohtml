      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/signup" class="inline-flex justify-center rounded-lg bg-violet-600 px-5 py-3 font-semibold text-white hover:bg-violet-500 transition-colors">
          Sign up for free
        </a>
        <a href="/signin" class="inline-flex justify-center rounded-lg border border-white/10 bg-white/5 px-5 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
