# Copy this file to .env and fill in your values.
# The example app reads these via environment variables (not dotenv).

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/goauth_example?sslmode=disable

# Full base URL of this application (used for email links)
APP_DOMAIN=http://localhost:8080

# HTTP port to listen on
PORT=8080

# --- Optional OAuth (leave blank to disable) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
